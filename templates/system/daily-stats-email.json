{
  "name": "daily-stats-email",
  "description": "Emails each workspace its daily summary of blocked traffic across all enforcement layers (waf, smart_firewall, access_rules, ids, …): totals + day-over-day, by-layer, by-action, top WAF rules (managed/custom), top countries/ASNs, unique IPs. Triggered by the daily_stats Kafka topic from the ax_prod pg_cron job daily_block_stats(). Renders with data.template, sends via resend.email to ${variables.email_recipients}. Install per-tenant and set email_recipients.",
  "trigger": {
    "type": "event",
    "topic": "daily_stats",
    "scope": "workspace"
  },
  "inputs": [
    {
      "name": "org_id",
      "type": "string"
    },
    {
      "name": "workspace_id",
      "type": "string"
    },
    {
      "name": "event",
      "type": "object",
      "default": {}
    }
  ],
  "steps": [
    {
      "name": "render",
      "activity": "data.template",
      "store": "render",
      "parameters": {
        "format": "html",
        "data": "${inputs.event}",
        "template": "<div style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1a1d23;\">\n  <div style=\"margin:0 0 22px;\">\n    <div style=\"font-size:40px;font-weight:700;line-height:1;color:#1a1d23;\">{{printf \"%.0f\" .total}}</div>\n    <div style=\"font-size:14px;color:#5a6178;margin-top:6px;\">requests blocked yesterday &middot; previous day {{printf \"%.0f\" .total_prev}}</div>\n  </div>\n  <h3 style=\"font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#006fff;margin:22px 0 8px;\">By layer</h3>\n  <table style=\"width:100%;border-collapse:collapse;font-size:14px;\">{{range $k, $v := .by_layer}}\n    <tr><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;color:#1a1d23;\">{{$k}}</td><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;text-align:right;font-weight:600;\">{{printf \"%.0f\" $v}}</td></tr>{{end}}\n  </table>\n  <h3 style=\"font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#006fff;margin:22px 0 8px;\">By action</h3>\n  <table style=\"width:100%;border-collapse:collapse;font-size:14px;\">{{range $k, $v := .by_action}}\n    <tr><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;color:#1a1d23;\">{{$k}}</td><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;text-align:right;font-weight:600;\">{{printf \"%.0f\" $v}}</td></tr>{{end}}\n  </table>\n  <p style=\"font-size:14px;color:#5a6178;margin:18px 0;\">Unique source IPs: <strong style=\"color:#1a1d23;\">{{printf \"%.0f\" .unique_ips}}</strong></p>\n  <h3 style=\"font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#006fff;margin:22px 0 8px;\">Top rules</h3>\n  <table style=\"width:100%;border-collapse:collapse;font-size:14px;\">{{range .top_rules}}\n    <tr><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;color:#1a1d23;\">{{.name}} {{if eq .type \"managed\"}}<span style=\"display:inline-block;margin-left:4px;padding:1px 7px;border-radius:10px;font-size:11px;font-weight:600;background:#e7f6ee;color:#16a34a;\">managed</span>{{else if eq .type \"custom\"}}<span style=\"display:inline-block;margin-left:4px;padding:1px 7px;border-radius:10px;font-size:11px;font-weight:600;background:#f3e8fd;color:#9333ea;\">custom</span>{{end}}</td><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;text-align:right;font-weight:600;\">{{printf \"%.0f\" .events}}</td></tr>{{end}}\n  </table>\n  <h3 style=\"font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#006fff;margin:22px 0 8px;\">Top countries</h3>\n  <table style=\"width:100%;border-collapse:collapse;font-size:14px;\">{{range .top_countries}}\n    <tr><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;color:#1a1d23;\">{{.country}}</td><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;text-align:right;font-weight:600;\">{{printf \"%.0f\" .events}}</td></tr>{{end}}\n  </table>\n  <h3 style=\"font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#006fff;margin:22px 0 8px;\">Top networks (ASN)</h3>\n  <table style=\"width:100%;border-collapse:collapse;font-size:14px;\">{{range .top_asns}}\n    <tr><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;color:#1a1d23;\">AS{{printf \"%.0f\" .asn}}</td><td style=\"padding:6px 0;border-bottom:1px solid #e8eaef;text-align:right;font-weight:600;\">{{printf \"%.0f\" .events}}</td></tr>{{end}}\n  </table>\n</div>\n"
      },
      "next": [
        {
          "step": "send"
        }
      ]
    },
    {
      "name": "send",
      "activity": "resend.email",
      "store": "send",
      "parameters": {
        "to": "${variables.email_recipients}",
        "subject": "Your daily security summary — ${inputs.event.date}",
        "template": "branded",
        "title": "Daily security summary — ${inputs.event.date}",
        "html": "${state.render.result}"
      }
    }
  ]
}
