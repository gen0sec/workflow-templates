{
  "name": "promote-rules",
  "description": "Promote rule changes from a source workspace into a target workspace, gated on a human approval. Loads both rule sets, diffs them, waits up to 30 minutes for a click-through on the rules.approve topic, then either applies the diff and emits a rules.audit event with event=rules.promoted, or emits event=rejected on a no/timeout. No-op short-circuit when the target is already in sync.",
  "inputs": [
    {
      "name": "org_id",
      "type": "string",
      "default": ""
    },
    {
      "name": "workspace_id",
      "type": "string",
      "default": ""
    },
    {
      "name": "source_ws",
      "type": "string",
      "default": ""
    },
    {
      "name": "target_ws",
      "type": "string",
      "default": ""
    },
    {
      "name": "requested_by",
      "type": "string",
      "default": ""
    }
  ],
  "steps": [
    {
      "name": "load_source",
      "activity": "rules.list",
      "store": "source",
      "parameters": {
        "org": "${inputs.org_id}",
        "workspace": "${inputs.source_ws}"
      },
      "next": [
        {
          "step": "load_target"
        }
      ]
    },
    {
      "name": "load_target",
      "activity": "rules.list",
      "store": "target",
      "parameters": {
        "org": "${inputs.org_id}",
        "workspace": "${inputs.target_ws}"
      },
      "next": [
        {
          "step": "plan"
        }
      ]
    },
    {
      "name": "plan",
      "activity": "rules.diff",
      "store": "plan",
      "parameters": {
        "source": "${state.source.rules}",
        "target": "${state.target.rules}"
      },
      "next": [
        {
          "step": "no_changes",
          "condition": "state.plan.count == 0"
        },
        {
          "step": "await_approval",
          "condition": "state.plan.count != 0"
        }
      ],
      "edge_matching_strategy": "first"
    },
    {
      "name": "await_approval",
      "wait_signal": {
        "topic": "rules.approve",
        "timeout": 1800000000000,
        "store": "approval",
        "on_timeout": "rejected"
      },
      "next": [
        {
          "step": "apply",
          "condition": "state.approval.decision == \"approve\""
        },
        {
          "step": "rejected",
          "condition": "state.approval.decision != \"approve\""
        }
      ],
      "edge_matching_strategy": "first"
    },
    {
      "name": "apply",
      "activity": "rules.apply",
      "store": "applied",
      "parameters": {
        "org": "${inputs.org_id}",
        "workspace": "${inputs.target_ws}",
        "changes": "${state.plan.changes}"
      },
      "next": [
        {
          "step": "audit"
        }
      ]
    },
    {
      "name": "audit",
      "activity": "print",
      "parameters": {
        "message": "promote-rules: promoted ${state.applied.applied} rule(s) from ${inputs.source_ws} to ${inputs.target_ws} (approved by ${inputs.requested_by})"
      }
    },
    {
      "name": "rejected",
      "activity": "print",
      "parameters": {
        "message": "promote-rules: promotion ${inputs.source_ws} -> ${inputs.target_ws} rejected"
      }
    },
    {
      "name": "no_changes",
      "activity": "print",
      "parameters": {
        "message": "promote-rules: target already in sync"
      }
    }
  ]
}